SIGPLAN_PROJECT_PATH=./sample_legacy_app
SIGPLAN_OUTPUT_DIR=./out
SIGPLAN_REPORT_DIR=reports
SIGPLAN_DEFAULT_MD_NAME=analysis.md

GEMINI_API_KEY=
SIGPLAN_AI_PROVIDER=gemini
SIGPLAN_AI_MODEL=gemini-2.5-flash
SIGPLAN_AI_FALLBACK_MODEL=gemini-2.5-flash-lite

SIGPLAN_DEFAULT_DEEP=1
SIGPLAN_DEFAULT_CONTEXTO=1
SIGPLAN_AI_CACHE_ENABLED=true
SIGPLAN_VERBOSE=true

SIGPLAN_DB_ACTIVE=homolog
SIGPLAN_DB_DRIVER=ODBC Driver 17 for SQL Server
SIGPLAN_DB_TRUST_CERTIFICATE=true
SIGPLAN_DB_ENCRYPT=false
SIGPLAN_DB_TIMEOUT=15

SIGPLAN_DB_HOMOLOG_SERVER=
SIGPLAN_DB_HOMOLOG_DATABASE=
SIGPLAN_DB_HOMOLOG_USERNAME=
SIGPLAN_DB_HOMOLOG_PASSWORD=

SIGPLAN_DB_PROD_SERVER=
SIGPLAN_DB_PROD_DATABASE=
SIGPLAN_DB_PROD_USERNAME=
SIGPLAN_DB_PROD_PASSWORD=

SIGBOARD_PROJECT_PATH=./sample_legacy_app
SIGBOARD_OUTPUT_DIR=./out
SIGBOARD_REPORT_DIR=reports
SIGBOARD_DEFAULT_MD_NAME=analysis.md

GEMINI_API_KEY=
SIGBOARD_AI_PROVIDER=gemini
SIGBOARD_AI_MODEL=gemini-2.5-flash
SIGBOARD_AI_FALLBACK_MODEL=gemini-2.5-flash-lite

SIGBOARD_DEFAULT_DEEP=1
SIGBOARD_DEFAULT_CONTEXTO=1
SIGBOARD_AI_CACHE_ENABLED=true
SIGBOARD_VERBOSE=true

SIGBOARD_DB_ACTIVE=homolog
SIGBOARD_DB_DRIVER=ODBC Driver 17 for SQL Server
SIGBOARD_DB_TRUST_CERTIFICATE=true
SIGBOARD_DB_ENCRYPT=false
SIGBOARD_DB_TIMEOUT=15

SIGBOARD_DB_HOMOLOG_SERVER=
SIGBOARD_DB_HOMOLOG_DATABASE=
SIGBOARD_DB_HOMOLOG_USERNAME=
SIGBOARD_DB_HOMOLOG_PASSWORD=

SIGBOARD_DB_PROD_SERVER=
SIGBOARD_DB_PROD_DATABASE=
SIGBOARD_DB_PROD_USERNAME=
SIGBOARD_DB_PROD_PASSWORD=

